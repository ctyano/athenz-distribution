              {
                "name": "token-exchange"
              }
            ]
          }
        ],
        "policies": [
          {
            "name": "Allow athenz-user-cert to exchange",
            "type": "client",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "clients": "[\"athenz-user-cert\"]"
            }
          },
          {
            "name": "Token Exchange Policy for athenz-user-cert",
            "type": "scope",
            "logic": "POSITIVE",
            "decisionStrategy": "UNANIMOUS",
            "config": {
              "resources": "[\"token-exchange.client.athenz-user-cert\"]",
              "scopes": "[\"token-exchange\"]",
              "applyPolicies": "[\"Allow athenz-user-cert to exchange\"]"
            }
          }
        ]
      }
    }
  ],
